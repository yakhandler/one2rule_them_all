# --- Claude Code local/machine-specific settings ---
# These hold absolute paths and per-machine permission allowlists; they're not
# meant to be shared. The skill itself (.claude/skills/) is NOT ignored.
.claude/settings.local.json
.claude/settings.json

# --- Backups created by reconcile_mcp.py ---
# The reconciler writes <config>.bak-<timestamp> next to each file it edits.
*.bak-*

# --- Backups created by reconcile_skills.py ---
# Overwritten skills are copied to <root>/.skill-backups/<timestamp>/ before writing.
.skill-backups/

# --- Test scaffolding / sandboxes ---
# Throwaway config trees generated by make_fixtures.py during smoke tests.
sandbox/
sb[0-9]*/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
